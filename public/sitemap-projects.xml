const projects = [
  "https://www.rpovoadata.tech/side-projects"
];

const projectUrls = projects.map(url => `
  <url>
    <loc>${url}</loc>
    <lastmod>${lastCommitDate}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
`).join("");

const sitemapProjects = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  ${projectUrls}
</urlset>`;

fs.writeFileSync("./dist/sitemap-projects.xml", sitemapProjects);