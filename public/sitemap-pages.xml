import { execSync } from "child_process";
import fs from "fs";

const lastCommitDate = execSync("git log -1 --format=%cI").toString().trim();

const baseUrl = "https://www.rpovoadata.tech";

const pages = [
  `${baseUrl}/`,
  `${baseUrl}/personal`,
  `${baseUrl}/professional`,
  `${baseUrl}/why-me`,
  `${baseUrl}/side-projects`,
  `${baseUrl}/contact`
];

const urls = pages.map(url => `
  <url>
    <loc>${url}</loc>
    <lastmod>${lastCommitDate}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>${url === "https://www.rpovoadata.tech/" ? "1.0" : "0.8"}</priority>
  </url>
`).join("");

const sitemapPages = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  ${urls}
</urlset>`;

// 👉 AQUI MUDA O NOME
fs.writeFileSync("./public/sitemap-pages.xml", sitemapPages);